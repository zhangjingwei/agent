{
    "venvPath": "./venv",
    "venv": "venv",
    "include": [
        ".",
        "api",
        "config", 
        "core",
        "llm",
        "orchestration",
        "scripts",
        "sdk/python",
        "tests",
        "tools"
    ],
    "exclude": [
        "**/__pycache__",
        "**/.mypy_cache", 
        "**/node_modules",
        "venv/**"
    ],
    "reportMissingImports": "warning",
    "reportMissingTypeStubs": "warning", 
    "pythonVersion": "3.9",
    "typeCheckingMode": "basic",
    "extraPaths": [
        ".",
        "./api",
        "./config",
        "./core", 
        "./llm",
        "./orchestration",
        "./scripts",
        "./sdk/python",
        "./tools"
    ]
}