# Zero Gateway 配置文件示例
# 复制此文件为 config.yaml 并填入实际的配置值

server:
  port: 8080
  read_timeout: 30s
  write_timeout: 30s
  idle_timeout: 60s

python:
  host: localhost
  port: 8082
  timeout: 5m
  insecure_skip_verify: true
  max_idle_conns: 100
  max_idle_conns_per_host: 20
  max_conns_per_host: 50
  idle_conn_timeout: 90s
  use_service_discovery: false
  service_name: zero-agent
  load_balance_strategy: round_robin

redis:
  host: localhost
  port: 6379
  password: ""  # 如果 Redis 设置了密码，请在此填入
  db: 0
  pool_size: 50

file:
  max_size: 100MB
  workers: 100
  queue_size: 1000
  allowed_paths:
    - /tmp
  temp_dir: /tmp/zero-agent

logging:
  level: info
  format: json
  output_file: ""  # 为空则输出到 stderr，或指定文件路径如 logs/gateway.log
  log_dir: logs

metrics:
  port: 9090
  path: /metrics
  health_interval: 30s

security:
  rate_limit_requests: 100
  rate_limit_window: 1m
  request_timeout: 30s
  max_request_size: 10MB
  cors_origins:
    - "*"
  circuit_breaker:
    enabled: true
    user_failure_threshold: 3
    user_success_threshold: 1
    user_timeout: 30s
    agent_failure_threshold: 10
    agent_success_threshold: 3
    agent_timeout: 60s
