# Nexus Agent Go Services Environment Variables

# Server Configuration
API_GATEWAY_PORT=8080
FILE_SERVICE_PORT=8081

# Python Agent Service
PYTHON_AGENT_HOST=localhost
PYTHON_AGENT_PORT=8082
PYTHON_AGENT_TIMEOUT=30s

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_POOL_SIZE=10

# File Service Configuration
FILE_MAX_SIZE=100MB
FILE_WORKERS=100
FILE_QUEUE_SIZE=1000
FILE_ALLOWED_PATHS=/tmp,/home/user

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Monitoring
METRICS_PORT=9090
HEALTH_CHECK_INTERVAL=30s

# Security
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=1m
REQUEST_TIMEOUT=30s
MAX_REQUEST_SIZE=10MB

# Development
DEBUG=false
CORS_ALLOWED_ORIGINS=*
